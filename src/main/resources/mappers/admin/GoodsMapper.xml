<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ch.ch9.mapper.admin.GoodsMapper">
    <select id="findByGname" parameterType="String" resultType="Goods">
        select * from goodstable where gname like concat('%', #{gname}, '%')
    </select>
    
    <update id="resetAutoIncrement">
        ALTER TABLE goodstable AUTO_INCREMENT = 1
    </update>
</mapper>