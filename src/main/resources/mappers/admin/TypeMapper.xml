<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ch.ch9.mapper.admin.TypeMapper">
    <select id="findByTname" parameterType="String" resultType="GoodsType">
        select * from goodstypetable where typename like concat('%', #{tname}, '%')
    </select>
</mapper>